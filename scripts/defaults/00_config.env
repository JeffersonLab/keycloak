##
# You can alternatively set these envs in deps.yaml file.  Some MUST be set in deps.yaml as they're used by
# container-entrypoint.sh, and include:
# - KC_BOOTSTRAP_ADMIN_USERNAME
# - KC_BOOTSTRAP_ADMIN_PASSWORD
# - KC_HOME
# - KC_BACKEND_URL
#
# To avoid having to override 00_config.env, you SHOULD also include in deps.yaml:
# - KC_RESOURCE
# - KC_CLIENT_NAME
# - KC_REDIRECT_URIS
##

export KC_REALM=test-realm
export KC_SECRET=yHi6W2raPmLvPXoxqMA7VWbLAA2WN0eB
export KC_REALM_DISPLAY_NAME="TEST REALM"
export KC_SERVICE_ACCOUNT_ENABLED=true
export KC_UPDATE_CLIENT_ROLES_MAPPER=true

# TIMEOUT UNITS IS SECONDS; 28800 Seconds = 8 Hours
export KC_SESSION_IDLE_TIMEOUT=28800

# LIFESPAN UNITS IS SECONDS; 86400 Seconds = 24 Hours
export KC_SESSION_MAX_LIFESPAN=86400