##
# You can alternatively set these envs in deps.yaml file.  Some MUST be set in deps.yaml as they're used by
# container-entrypoint.sh, and include:
# - KC_BOOTSTRAP_ADMIN_USERNAME
# - KC_BOOTSTRAP_ADMIN_PASSWORD
# - KC_HOME
# - KC_BACKEND_URL
##

export KEYCLOAK_REALM=test-realm
export KEYCLOAK_RESOURCE=test
export KEYCLOAK_SECRET=yHi6W2raPmLvPXoxqMA7VWbLAA2WN0eB
export KEYCLOAK_REALM_DISPLAY_NAME="TEST REALM"

# TIMEOUT UNITS IS SECONDS; 28800 Seconds = 8 Hours
export KEYCLOAK_SESSION_IDLE_TIMEOUT=28800

# LIFESPAN UNITS IS SECONDS; 86400 Seconds = 24 Hours
export KEYCLOAK_SESSION_MAX_LIFESPAN=86400

export KEYCLOAK_CLIENT_NAME=test
export KEYCLOAK_SERVICE_ACCOUNT_ENABLED=true
export KEYCLOAK_REDIRECT_URIS='["https://localhost:8443/test/*"]'